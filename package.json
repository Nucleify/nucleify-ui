{
  "name": "nucleify-ui",
  "version": "0.2.1",
  "description": "Lit 3 web component library with optional interactive playground.",
  "type": "module",
  "sideEffects": [
    "dist/components/**/nui-*.js"
  ],
  "files": [
    "dist",
    "src",
    "index.html",
    "bin",
    "web-dev-server.config.js",
    "resolve-ts-imports-plugin.js",
    "README.md"
  ],
  "bin": {
    "nucleify-ui-playground": "./bin/playground.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./theme": {
      "types": "./dist/theme.d.ts",
      "import": "./dist/theme.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./styles/*": "./dist/styles/*",
    "./types/component-events": {
      "types": "./dist/types/component-events.d.ts",
      "import": "./dist/types/component-events.js",
      "default": "./dist/types/component-events.js"
    },
    "./types/nui-type": {
      "types": "./dist/types/nui-type.d.ts",
      "import": "./dist/types/nui-type.js",
      "default": "./dist/types/nui-type.js"
    },
    "./components/nui-*/types": {
      "types": "./dist/components/nui-*/types.d.ts",
      "import": "./dist/components/nui-*/types.js",
      "default": "./dist/components/nui-*/types.js"
    },
    "./components/nui-*": {
      "types": "./dist/components/nui-*/nui-*.d.ts",
      "import": "./dist/components/nui-*/nui-*.js",
      "default": "./dist/components/nui-*/nui-*.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "start": "web-dev-server --config web-dev-server.config.js",
    "playground": "web-dev-server --config web-dev-server.config.js",
    "build": "node scripts/run-check.mjs build node scripts/build.mjs",
    "check": "node scripts/run-check.mjs biome npx biome check .",
    "write": "biome check --write .",
    "prepublishOnly": "npm run build",
    "prepare": "node scripts/prepare.mjs",
    "typeslint": "node scripts/run-check.mjs tsc npx tsc -p tsconfig.json --noEmit",
    "types:audit": "node scripts/run-check.mjs types-audit node scripts/audit-component-types.mjs",
    "test": "node scripts/run-check.mjs vitest npx vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "slint": "node scripts/run-check.mjs stylelint npx stylelint \"src/**/*.css\" --allow-empty-input",
    "pack:check": "node scripts/run-check.mjs pack-check node scripts/pack-check.mjs",
    "dedupe:check": "node scripts/run-check.mjs dedupe npm dedupe --dry-run",
    "lockfile:check": "node scripts/run-check.mjs lockfile node scripts/lockfile-check.mjs",
    "audit:check": "node scripts/run-check.mjs audit npm audit --audit-level=high"
  },
  "dependencies": {
    "@web/dev-server": "0.4.6",
    "chart.js": "4.5.1",
    "iconify-icon": "3.0.0",
    "lit": "3.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@vitest/ui": "4.1.9",
    "@web/dev-server-rollup": "0.6.4",
    "esbuild": "0.28.1",
    "glob": "11.1.0",
    "happy-dom": "20.10.6",
    "husky": "9.1.7",
    "rollup-plugin-esbuild": "6.2.1",
    "stylelint": "17.14.0",
    "stylelint-config-standard": "40.0.0",
    "stylelint-config-standard-scss": "17.0.0",
    "stylelint-order": "8.1.1",
    "typescript": "5.8.3",
    "vitest": "4.1.9"
  },
  "peerDependencies": {
    "chart.js": "4.5.1",
    "iconify-icon": "3.0.0",
    "lit": "3.0.0"
  },
  "peerDependenciesMeta": {
    "chart.js": {
      "optional": true
    }
  },
  "keywords": [
    "lit",
    "web-components",
    "ui",
    "design-system"
  ],
  "license": "MIT",
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
